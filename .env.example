# Transit Pulse — local development environment variables.
# Copy to .env and adjust as needed. This is a personal portfolio project
# using publicly available GTFS feeds; not affiliated with any transit agency.

# Kafka (host access uses the PLAINTEXT_HOST listener on port 29092)
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# MinIO (S3-compatible local object storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Public GTFS feeds — King County Metro / Puget Sound region (real URLs, for reference)
GTFS_STATIC_URL=https://metro.kingcounty.gov/gtfs/google_transit.zip
GTFS_REALTIME_URL=https://api.pugetsound.onebusaway.org/api/gtfs_realtime/vehicle-positions-for-agency/1.pb
# OneBusAway public TEST key for local dev; dedicated keys need ~20 business days for approval.
# Production would swap in a dedicated key here.
GTFS_REALTIME_API_KEY=TEST
GTFS_REALTIME_POLL_INTERVAL_SECONDS=30

# AWS region placeholder for a future cloud deployment (S3, MSK, etc.)
AWS_REGION=us-west-2

# GTFS static Parquet ingestion date folder in raw-zone (match gtfs_static_loader run)
GTFS_STATIC_INGESTION_DATE=2026-07-01
RAW_ZONE_BUCKET=raw-zone
CURATED_ZONE_BUCKET=curated-zone
# Set to true to print closed window batches to the terminal instead of MinIO
DELAY_CALCULATOR_DEBUG_CONSOLE=false
# Set to true to print Kafka vs static trip_id samples before the main job runs
DELAY_CALCULATOR_DEBUG_TRIP_IDS=false
# Set to true for one-time batch membership check (full static set vs Kafka batch)
DELAY_CALCULATOR_DEBUG_TRIP_ID_MEMBERSHIP=false
# Set to true to print stop_id / current_stop_sequence null rates and exit (no streaming)
DELAY_CALCULATOR_DEBUG_STOP_FIELDS=false
# Join mode: auto | trip_id_stop_id | trip_id_nearest (auto picks from null-rate diagnostic)
DELAY_CALCULATOR_JOIN_MODE=auto
# Set to true to wipe the streaming checkpoint before start (fixes offset conflicts after Ctrl+C)
DELAY_CALCULATOR_RESET_CHECKPOINT=false
# Separate checkpoint for the Kafka→raw-zone vehicle-position archiver sink
DELAY_CALCULATOR_ARCHIVER_CHECKPOINT_DIR=/tmp/transit-pulse-archiver-checkpoint

# Airflow web UI host port (container still listens on 8080 internally)
AIRFLOW_WEBSERVER_PORT=8081

# Local warehouse stand-in (Postgres) for curated load — see warehouse/load_curated.py
WAREHOUSE_BACKEND=postgres
WAREHOUSE_HOST=127.0.0.1
WAREHOUSE_PORT=5433
WAREHOUSE_DATABASE=warehouse
WAREHOUSE_USER=airflow
WAREHOUSE_PASSWORD=airflow
# Production Redshift only:
# WAREHOUSE_BACKEND=redshift
# REDSHIFT_COPY_IAM_ROLE=arn:aws:iam::<account-id>:role/<redshift-copy-role>

